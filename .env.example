# Artmind Configuration

# Ollama model for image descriptions (default: gemma4:e4b)
ARTMIND_IMAGE_MODEL=gemma4:e4b

# Timeout in seconds for Ollama requests (default: 120)
ARTMIND_OLLAMA_TIMEOUT=600

# Knowledge Graph — Neo4j connection
ARTMIND_KG_NEO4J_URI=neo4j://127.0.0.1:7687
ARTMIND_KG_NEO4J_USERNAME=xxxx
ARTMIND_KG_NEO4J_PASSWORD=xxxx
ARTMIND_KG_NEO4J_DATABASE=xxxx

# Knowledge Graph — LLM (Ollama)
ARTMIND_KG_LLM_PROVIDER=ollama
ARTMIND_KG_LLM_URL=http://localhost:11434
ARTMIND_KG_LLM_MODEL=qwen3.6:35b-a3b-coding-nvfp4

# Knowledge Graph — Embeddings (Ollama)
ARTMIND_KG_EMBEDDINGS_PROVIDER=ollama
ARTMIND_KG_EMBEDDINGS_URL=http://localhost:11434
ARTMIND_KG_EMBEDDINGS_MODEL=nomic-embed-text:latest
ARTMIND_KG_EMBEDDING_DIMENSIONS=768

# Knowledge Graph — Chunking
# Max characters per chunk sent to the LLM (default: 6000 ≈ 1500 tokens for nomic-embed-text)
ARTMIND_KG_CHUNK_SIZE=7500
